    "HandleLineBreak": false,
    "InvalidCharToTrimRegex": "[\\=\\ ]",
    "InvalidCharToReplaceRegex": "[\\\\<>:\\*\\?]",
    "InvalidCharReplacement": "_",
    "TableOfContentsModes": "Grouped,IncludeSummary",
    "UrlFormat": "[{0}]({1} '{2}')",
    "UseFullUrl": false
