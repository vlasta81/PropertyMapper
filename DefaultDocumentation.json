{
  "$schema": "https://raw.githubusercontent.com/Doraku/DefaultDocumentation/master/source/DefaultDocumentation.Common/Configuration/Settings.schema.json",
  "LogLevel": "Information",
  "AssemblyPageName": "index",
  "GeneratedAccessModifiers": "Api",
  "IncludeUndocumentedItems": false,
  "GeneratedPages": "Namespaces,Types,Members",
  "LinksOutputFilePath": "docs/PropertyMapper.links",
  "AssemblyFilePath": "src/PropertyMapper/bin/Release/net10.0/PropertyMapper.dll",
